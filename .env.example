# Copiar a .env y ajustar por entorno (nunca versionar .env, ver .gitignore).
# ADR-12: la config de conexión vive acá para que la migración local -> nube
# (docs/CLAUDE.md §6) sea solo un cambio de estas variables, sin tocar código.

# Broker MQTT (ADR-09)
MQTT_HOST=localhost
MQTT_PORT=1883

# Mock Starlink (ADR-06/07/08)
STARLINK_NODE_ID=lit-cordoba-01
CHAOS_PROFILE=CALM
TIME_WARP_FACTOR=1
